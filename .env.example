# Credenciales de la API "MiCorreo" de Correo Argentino (para cotizar envíos en vivo).
# Cargalas en Vercel: Project Settings -> Environment Variables.
# Se solicitan a Correo Argentino al dar de alta la integración MiCorreo/PaqAr.
CORREO_USER=
CORREO_PASSWORD=
CORREO_CUSTOMER_ID=
CORREO_ORIGIN_CP=1704
# Ambiente de la API: "prod" (producción) o "test" (testing)
CORREO_ENV=prod
